# Get your free API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# MongoDB connection string (default is local MongoDB)
MONGODB_URI=mongodb://localhost:27017/cinetale

# Server port
PORT=3000

# Secret key for signing JWT tokens (change this to something random!)
JWT_SECRET=your_super_secret_key_change_this_to_something_random
